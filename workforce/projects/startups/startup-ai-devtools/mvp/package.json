    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "drizzle-orm": "^0.29.0",
    "fastify": "^4.24.0",
    "ioredis": "^5.3.0",
    "pg": "^8.11.0",
    "postgres": "^3.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.15",
    "@types/node": "^20.8.0",
    "@types/pg": "^8.10.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "eslint": "^8.52.0",
    "prettier": "^3.0.0",
